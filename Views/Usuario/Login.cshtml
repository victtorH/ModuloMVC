@model ModuloMVC.ViewModels.UserViewModel
@{
    Layout =  null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>UXOLIST - Cadastro Premium (Bootstrap)</title>
    <!-- Bootstrap 5 CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <!-- GSAP -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.2/gsap.min.js"></script>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
     
   <link rel="stylesheet" href="~/css/CadastroELogin.css" asp-append-version="true" />

</head>
<body>

    <div >
        <!-- BARRA DE PROGRESSO NO TOPO -->
        <div class="top-progress-container">
            <div id="progressBar" class="top-progress-bar"></div>
        </div>

           <a asp-controller="Home" asp-action="index" class="back-link d-inline-block mb-3 text-decoration-none text-muted">
              <i class="bi bi-arrow-left-circle"></i>
            </a>

<section id="CardCadastro" class="main-wrapper">

        <!-- FORMULÁRIO -->
        <div class="form-content">
            <div class="header-section mb-4 animate-in">
                <h1 class="h2 fw-bolder text-dark mb-1">Login na sua conta</h1>
                <p class="text-secondary small">Unlock exclusive features and start building your dream project today.</p>
            </div>

            <form asp-action="Login" method="post" id="signupForm">
   
                <div class="input-group-custom animate-in">
                    <label asp-for="email" class="input-label" for="email">Email</label>
                    <input asp-for="email" type="email" id="email" class="input-control" placeholder="Your email" required>
                    <div class="error-msg">A valid email is required.</div>
                </div>

                <div class="input-group-custom animate-in">
                    <label asp-for="password" class="input-label" for="password">Password</label>
                    <input asp-for="password" type="password" id="password" class="input-control" placeholder="Create a password" >
                    <div class="error-msg">Password must be at least 6 characters.</div>
                </div>

                    <div class="form-actions animate-in">
                    <div class="checkbox-group">
                        <input asp-for="lembrar" type="checkbox" id="lembrar" name="lembrar" />
                        <label asp-for="lembrar" class="text-sm text-champagne-muted">Lembrar de mim</label>
                    </div>
                </div>

                <button type="submit" class="btn-submit animate-in" id="submitBtn">
                    conect account
                </button>
            </form>

            <div class="social-divider animate-in">
                <span>Or</span>
            </div>

            <div class="d-flex gap-3 animate-in">
                <button class="btn-social">
                    <img src="https://www.gstatic.com/images/branding/product/1x/googleg_48dp.png" style="width: 20px; height: 20px;" alt="Google">
                </button>
                <button class="btn-social">
                    <i class="bi bi-facebook text-primary fs-5"></i>
                </button>
            </div>
        </div>

        <!-- PAINEL VISUAL -->
        <div class="visual-panel">
            <div class="art-overlay"></div>
            <div class="bloom-shape"></div>

            <div class="logo-text animate-in">T&NANCY</div>

            <div class="testimonial-box animate-in">
                 <div class="shape-spacer"></div>
                <p class="quote">
                    "Volte ao T&nancy agora: recupere seu tempo e acelere resultados. Faça o login e assuma o controle total!"
                </p>
                <div class="author-box">
                    <span class="author-name">Ops!</span>
                    <span class="author-title">Não possue conta ?</span>
                </div>
            </div>

            <div class="slider-nav animate-in">
                <a asp-action="SingIn" class="arrow-btn">Cadastro</a>
            </div>
        </div>
    </div>
</section>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>

       <script src="~/js/CadastroELogin.js" asp-append-version="true"></script>
</body>
</html>