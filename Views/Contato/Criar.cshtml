@model ModuloMVC.Models.Contato

@{
    ViewData["Title"] = "Novo Contato";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f8f9fa;
        color: #333;
    }

    .create-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 25px rgba(0, 0, 0, 0.05);
        border: none;
    }

    .form-label {
        font-weight: 600;
        font-size: 0.85rem;
        color: #555;
        margin-bottom: 0.4rem;
    }


    .custom-textarea {
        border-radius: 8px;
        resize: none;
        height: 150px;
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }

    .input-group-text {
        background-color: #fdfdfd;
        color: #adb5bd;
    }

    .action-footer {
        display: flex;
        gap: 12px;
        margin-top: 2.5rem;
        padding-top: 1.5rem;
        border-top: 1px solid #eee;
    }


    .email-input:valid:not(:placeholder-shown) {
        border-color: #198754 !important;
    }


    .email-input:valid:not(:placeholder-shown)~.validation-indicator .bi-check-circle-fill {
        opacity: 1;
        color: #198754;
        transform: scale(1);
    }

    .validation-indicator .bi-check-circle-fill {
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            
            <a asp-action="Index" class="text-decoration-none text-muted small mb-3 d-inline-block">
                <i class="bi bi-chevron-left me-1"></i>Voltar para a lista
            </a>

            <div class="create-card p-4 p-md-5">
                <header class="mb-4">
                    <div class="d-flex align-items-center mb-2">
                        <div class="bg-primary bg-opacity-10 p-2 rounded-3 me-3">
                            <i class="bi bi-person-plus text-primary h4 mb-0"></i>
                        </div>
                        <h2 class="fw-bold h4 mb-0">Novo Contato</h2>
                    </div>
                    <p class="text-muted small">Insira as informações básicas e observações do contato.</p>
                </header>

                <form asp-action="Criar">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="mb-4">
                        <label asp-for="Nome" class="form-label text-uppercase">Nome Completo</label>
                        <div class="input-group">
                            <span class="input-group-text border-end-0"><i class="bi bi-person"></i></span>
                            <input asp-for="Nome" class="form-control border-start-0" autofocus />
                        </div>
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label text-uppercase">E-mail Profissional / Pessoal</label>
    
                        <div class="input-group">
                            <span class="input-group-text border-end-0 bg-white">
                                <i class="bi bi-envelope-at text-muted"></i>
                            </span>
        
                            <input type="email" asp-for="Email"
                                   class="form-control border-start-0 border-end-0 px-2 email-input"
                                   placeholder="nome@exemplo.com.br" />
               
                            <span class="input-group-text border-start-0 bg-white validation-indicator">
                                <i class="bi bi-check-circle-fill"></i>
                            </span>
                        </div>
    
                        <div class="form-text mt-1 text-muted small d-flex justify-content-between">
                            <span>Insira um endereço válido (ex: @@gmail.com).</span>
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Telefone" class="form-label text-uppercase">Telefone / Celular</label>
                        <div class="input-group">
                            <span class="input-group-text border-end-0"><i class="bi bi-whatsapp"></i></span>
                            <input type="tel" asp-for="Telefone" class="form-control border-start-0"
                                   placeholder="(11) 99999-9999" />
                        </div>
                        <span asp-validation-for="Telefone" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Descricao" class="form-label text-uppercase">Observações / Descrição</label>
                        <div class="input-group">
                            <span class="input-group-text border-end-0 align-items-start pt-2">
                                <i class="bi bi-chat-left-text"></i>
                            </span>
                            <textarea asp-for="Descricao" class="form-control border-start-0 custom-textarea"
                                      placeholder="Adicione detalhes sobre como conheceu este contato ou informações relevantes..."></textarea>
                        </div>
                        <div class="form-text d-flex justify-content-between">
                            <span>Opcional</span>
                            <span id="charCount">0 / 300</span>
                        </div>
                        <span asp-validation-for="Descricao" class="text-danger small"></span>
                    </div>


                            <div class="action-footer">
                                <button type="submit" class="btn btn-primary px-4 py-2 shadow-sm fw-semibold flex-grow-1">
                                    <i class="bi bi-check-lg me-2"></i>Salvar Contato
                                </button>
                                <a asp-action="Index" class="btn btn-outline-secondary px-4 py-2">Cancelar</a>
                            </div>
                        </form>
                    </div>
            
                    <p class="text-center mt-4 text-muted small">
                        Todos os dados são armazenados de forma segura.
                    </p>
                </div>
            </div>
        </div>

        <script>

            const textarea = document.querySelector('textarea[Name ="Descricao"]');
            const charCount = document.getElementById('charCount');

            textarea.addEventListener('input', () => {
                const length = textarea.value.length;
                charCount.textContent = `${length} / 300`;
        
                if (length >= 300) charCount.classList.add('text-danger');
                else charCount.classList.remove('text-danger');
            });
        </script>