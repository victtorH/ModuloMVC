@model ModuloMVC.Models.Contato

@{
    ViewData["Title"] = "Detalhes";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f8f9fa;
        color: #333;
    }

    /* Gestalt: Figura e Fundo - Destacando o card de informações do fundo da página */
    .details-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 8px 24px rgba(0, 0, 0, 0.06);
        border: none;
        overflow: hidden;
    }

    /* Lei da Semelhança: Trazendo o mesmo padrão de avatar da página Index */
    .avatar-profile {
        width: 80px;
        height: 80px;
        border-radius: 50%;
        background-color: #e9ecef;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        color: #0d6efd;
        border: 2px solid #fff;
        box-shadow: 0 4px 10px rgba(0, 0, 0, 0.1);
    }

    /* Header com gradiente sutil para separar visualmente a identidade dos dados */
    .details-header {
        background: linear-gradient(135deg, #f8f9fa 0%, #e9ecef 100%);
        padding: 2rem;
        border-bottom: 1px solid #dee2e6;
        text-align: center;
    }

    .info-label {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #6c757d;
        font-weight: 600;
        margin-bottom: 0.25rem;
    }

    .info-value {
        font-size: 1.1rem;
        font-weight: 500;
        color: #212529;
    }

    /* Área da descrição com fundo diferenciado (Lei da Região Comum) */
    .description-box {
        background-color: #f8f9fa;
        border-radius: 8px;
        padding: 1rem;
        border-left: 4px solid #0d6efd;
        min-height: 80px;
    }

    .action-bar {
        background-color: #fff;
        padding: 1.5rem 2rem;
        border-top: 1px solid #eee;
        display: flex;
        gap: 10px;
        justify-content: center;
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            
            <a asp-action="Index" class="text-decoration-none text-muted small mb-3 d-inline-block">
                <i class="bi bi-arrow-left me-1"></i>Voltar para a lista
            </a>

            <div class="details-card">
                <div class="details-header d-flex flex-column align-items-center">
                    <div class="avatar-profile mb-3 fw-bold">
                        @(string.IsNullOrEmpty(Model.Nome) ? "?" : Model.Nome.Substring(0, 1).ToUpper())
                    </div>
                    <h2 class="h3 fw-bold mb-1">@Html.DisplayFor(model => model.Nome)</h2>
                    
                    <div class="mt-2">
                        @if (Model.Status)
                        {
                            <span class="badge rounded-pill bg-success-subtle text-success border border-success px-3 py-2">
                                <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem; vertical-align: middle;"></i>
                                Contato Ativo
                            </span>
                        }
                        else
                        {
                            <span class="badge rounded-pill bg-secondary-subtle text-secondary border px-3 py-2">
                                <i class="bi bi-circle-fill me-1" style="font-size: 0.5rem; vertical-align: middle;"></i>
                                Contato Inativo
                            </span>
                        }
                    </div>
                </div>

                <div class="p-4 p-md-5">

                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="d-flex align-items-start mb-4">
                                <div class="bg-light p-2 rounded me-3 text-primary">
                                    <i class="bi bi-envelope-check"></i>
                                </div>
                                <div>
                                    <div class="info-label">E-mail Profissional / Pessoal</div>
                                    <div class="info-value">@Html.DisplayFor(model => model.Email)</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="d-flex align-items-start mb-4">
                                <div class="bg-light p-2 rounded me-3 text-primary">
                                    <i class="bi bi-telephone fs-5"></i>
                                </div>
                                <div>
                                    <div class="info-label">Telefone / Celular</div>
                                    <div class="info-value">@Html.DisplayFor(model => model.Telefone)</div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-4">
                        <div class="col-12">
                            <div class="d-flex align-items-start mb-4">
                                <div class="bg-light p-2 rounded me-3 text-primary">
                                    <i class="bi bi-book fs-5"></i>
                                </div>
                                <div>
                                    <div class="info-label">Observações / Descrição</div>
                                    <div class="info-value">@Html.DisplayFor(model => model.Descricao)</div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>