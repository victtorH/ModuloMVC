@model ModuloMVC.Models.Contato

@{
    ViewData["Title"] = "Editar Contato";
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">

<style>
    body {
        background-color: #f8f9fa;
        color: #333;
    }
    
    .gestalt-edit-card {
        background: white;
        border-radius: 16px;
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.08);
        border: none;
        overflow: hidden;
    }

    .form-label {
        font-weight: 600;
        color: #495057;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
    }

    .form-control:focus {
        border-color: #0d6efd;
        box-shadow: 0 0 0 0.25 margin-rgba(13, 110, 253, 0.15);
    }

    .custom-textarea {
        border-radius: 8px;
        resize: none;
        /* Evita que o usuário quebre o layout */
        height: 150px;
        border-top-left-radius: 0;
        border-bottom-left-radius: 0;
    }

    /* Gestalt: Proximidade e Agrupamento dos botões de ação */
    .action-group {
        background-color: #f8f9fa;
        padding: 1.5rem 2rem;
        margin: 2rem -2rem -2rem -2rem;
        display: flex;
        gap: 12px;
        justify-content: flex-end;
    }

    /* Email */
    /* Detalhe Único: Feedback Visual Dinâmico de Validação */
    .email-input:valid:not(:placeholder-shown) {
        border-color: #198754 !important;
        /* Verde Sucesso do Bootstrap */
    }

    /* Faz o ícone de 'Check' aparecer suavemente quando o e-mail está correto */
    .email-input:valid:not(:placeholder-shown)~.validation-indicator .bi-check-circle-fill {
        opacity: 1;
        color: #198754;
        transform: scale(1);
    }

    .validation-indicator .bi-check-circle-fill {
        opacity: 0;
        transform: scale(0.5);
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
        /* Efeito "mola" (bounce) */
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-12 col-md-8 col-lg-6">
            
            <a asp-action="Index" class="text-decoration-none text-muted mb-4 d-inline-block">
                <i class="bi bi-arrow-left me-1"></i> Voltar para a lista
            </a>

            <div class="gestalt-edit-card p-4 p-md-5">
                <header class="mb-4">
                    <h2 class="fw-bold h4 mb-1">Editar Contato</h2>
                    <p class="text-muted small">Atualize as informações do contato selecionado.</p>
                </header>

                <form asp-action="Editar">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    <input type="hidden" asp-for="Id" />

                    <div class="mb-4">
                        <label asp-for="Nome" class="form-label">Nome Completo</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white text-muted border-end-0">
                                <i class="bi bi-person"></i>
                            </span>
                            <input asp-for="Nome" class="form-control border-start-0 ps-0"
                                   placeholder="Ex: João Silva" />
                        </div>
                        <span asp-validation-for="Nome" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Email" class="form-label text-uppercase">E-mail Profissional / Pessoal</label>
    
                        <div class="input-group">
                            <span class="input-group-text border-end-0 bg-white">
                                <i class="bi bi-envelope-at text-muted"></i>
                            </span>
        
                            <input type="email" asp-for="Email"
                                   class="form-control border-start-0 border-end-0 px-0 email-input"
                                   placeholder="nome@exemplo.com.br" />
               
                            <span class="input-group-text border-start-0 bg-white validation-indicator">
                                <i class="bi bi-check-circle-fill"></i>
                            </span>
                        </div>
    
                        <div class="form-text mt-1 text-muted small d-flex justify-content-between">
                            <span>Insira um endereço válido (ex: @@gmail.com).</span>
                        </div>
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Telefone" class="form-label">Telefone / Celular</label>
                        <div class="input-group">
                            <span class="input-group-text bg-white text-muted border-end-0">
                                <i class="bi bi-telephone"></i>
                            </span>
                            <input type="tel" asp-for="Telefone" class="form-control border-start-0 ps-0"
                                   placeholder="(11) 99999-9999" />
                        </div>
                        <span asp-validation-for="Telefone" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <label asp-for="Descricao" class="form-label ">Observações / Descrição</label>
                        <div class="input-group">
                            <span class="input-group-text border-end-0 align-items-start pt-2">
                                <i class="bi bi-chat-left-text"></i>
                            </span>
                            <textarea asp-for="Descricao" class="form-control border-start-0 custom-textarea"
                                      placeholder="Adicione detalhes sobre como conheceu este contato ou informações relevantes..."></textarea>
                        </div>
                        <div class="form-text d-flex justify-content-between">
                            <span>Opcional</span>
                            <span id="charCount">0 / 300</span>
                        </div>
                        <span asp-validation-for="Descricao" class="text-danger small"></span>
                    </div>

                    <div class="mb-4">
                        <div class="form-check form-switch p-0 d-flex align-items-center justify-content-between">
                            <label asp-for="Status" class="form-label mb-0" style="cursor: pointer;">Status do Contato
                                (Ativo)</label>
                                <input asp-for="Status" class="form-check-input ms-0" type="checkbox" role="switch"
                                       style="width: 2.5em; height: 1.25em;">
                                </div>
                                <div class="form-text mt-2">Esté contato pode ser chamado pelo numero atual.</div>
                            </div>

                            <div class="action-group">
                                <a asp-action="Index" class="btn btn-light px-4 border">Cancelar</a>
                                <button type="submit" class="btn btn-primary px-4 shadow-sm">
                                    <i class="bi bi-check2-circle me-2"></i>Salvar Alterações
                                </button>
                            </div>
                        </form>
                    </div>

                    <p class="text-center text-muted mt-4 small">
                        ID do Registro: <span class="fw-bold">@Model.Id</span>
                    </p>

                </div>
            </div>
        </div>

        <script>
            // Heurística de Visibilidade do Status: Contador de caracteres em tempo real
            const textarea = document.querySelector('textarea[Name="Descricao"]');
            const charCount = document.getElementById('charCount');

            textarea.addEventListener('input', () => {
                const length = textarea.value.length;
                charCount.textContent = `${length} / 300`;
        
                if (length >= 300) charCount.classList.add('text-danger');
                else charCount.classList.remove('text-danger');
            });
        </script>